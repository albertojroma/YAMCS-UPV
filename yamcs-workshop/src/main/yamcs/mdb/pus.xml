                            <Comparison value="4" parameterRef="message_subtype_ID_TM" />
                        </ComparisonList>
                    </RestrictionCriteria>
                </BaseContainer>
            </SequenceContainer>

            <SequenceContainer name="TM(2,6)_report_angle_stats">
                <EntryList>
