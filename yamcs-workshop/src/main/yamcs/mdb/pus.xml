            <!-- Service [04] Payload Operations  -->

            <SequenceContainer name="TM(4,2)_photo_capture_report">
                <EntryList>
                </EntryList>
                <BaseContainer containerRef="packet_header_TM">
                    <RestrictionCriteria>
