                            <Comparison value="8" parameterRef="message_subtype_ID_TM" />
                        </ComparisonList>
                    </RestrictionCriteria>
                </BaseContainer>
            </SequenceContainer>

            <!-- Service [03] Request Parameters Values -->

            <SequenceContainer name="TM(3,2)_heater_percentage_report">
